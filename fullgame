    // =========================
    // TIME / CORES (SEU DIFERENCIAL)
    // =========================
    static void EscolherTime()
    {
        Console.WriteLine("\nEscolha seu time:");
        Console.WriteLine("1 - Corinthians / 2 - CAP / 3 - Coxa / 4 - Nenhum");

        int t = int.Parse(Console.ReadLine());

        switch (t)
        {
            case 1:
                Console.ForegroundColor = ConsoleColor.White;
                Console.BackgroundColor = ConsoleColor.Black;
                break;
            case 2:
                Console.ForegroundColor = ConsoleColor.Red;
                Console.BackgroundColor = ConsoleColor.Black;
                break;
            case 3:
                Console.ForegroundColor = ConsoleColor.Green;
                Console.BackgroundColor = ConsoleColor.White;
                break;
            case 4:
                Console.ForegroundColor = ConsoleColor.White;
                Console.BackgroundColor = ConsoleColor.Black;
                Console.WriteLine("Entao agora vocé é Corinthians, bem vindo ao bando de louco");
                break;
        }

        Console.Clear();
    }

    // =========================
    // CONFIGURAÇÕES
    // =========================
    static void Configuracoes()
    {
        Console.Write("Número de tentativas: ");
        if (int.TryParse(Console.ReadLine(), out int val))
            tentativasMax = val;
    }

    // =========================
    // STATS
    // =========================
    static void MostrarStats()
    {
        Console.WriteLine($"Vitórias: {vitorias}");
        Console.WriteLine($"Derrotas: {derrotas}");
        Console.ReadKey();
    }

    // =========================
    // ANIMAÇÃO (SEU TOQUE FINAL)
    // =========================
    static void Corrida()
    {
        string[][] frames = new string[][]
        {
            new string[] { " O ", "/|\\", "/ \\" },
            new string[] { " O ", "/|\\", " /\\" }
        };

        for (int x = 0; x < Console.WindowWidth - 10; x++)
        {
            Console.Clear();

            var frame = frames[x % 2];

            for (int y = 0; y < frame.Length; y++)
            {
                Console.SetCursorPosition(x, 5 + y);
                Console.Write(frame[y]);
            }

            Console.SetCursorPosition(x, 10);
            Console.Write("VAI CORINTHIANS!!! ⚫⚪");

            Thread.Sleep(80);
        }
    }
}
