using System;
using System.Threading;

class Program
{
    static void Main()
    {
        Console.CursorVisible = false;
        Correndo();
        Console.CursorVisible = true;
    }

    static void Correndo()
    {
        string[] frames = new string[]
        {
@"
  O
 /|\
 / \
",
@"
 \O
  |\
 / \
"
        };

        int larguraTela = Console.WindowWidth;

        for (int pos = 0; pos < larguraTela - 20; pos++)
        {
            foreach (var frame in frames)
            {
                Console.Clear();

                // Desenha o bonequinho na posição horizontal
                Console.SetCursorPosition(pos, 5);
                Console.WriteLine(frame);

                // Escreve o grito abaixo
                Console.SetCursorPosition(pos, 10);
                Console.WriteLine("VAI CORINTHIANS!!! ⚫⚪");

                Thread.Sleep(100);
            }
        }

        Console.SetCursorPosition(0, 15);
        Console.WriteLine("🏆 ELE FOI EMBORA COMEMORANDO!");
    }
}
